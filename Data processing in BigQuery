2. Create one table for diagnoses/rhythms + :
SELECT
  patient_id,
  ecg_id,
  recording_date,
  REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") AS diagnose,
  CAST(CAST(REGEXP_EXTRACT(pair, r":\s*([0-9.]+)") AS FLOAT64) AS INT64) AS value,
  case
    when age = 0 or age is null then 'No data'
    when age <= 18 then '0-18'
    when age <= 39 then '19-39'
    when age <= 59 then '40-59'
    when age <= 69 then '60-69'
    when age >= 70 then '70+'
  end as age_category,
  CASE 
    WHEN REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") = 'NORM' THEN 'Normal'
    WHEN REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") IN ('IMI', 'ASMI', 'ALMI', 'LMI', 'AMI', 'PMI') THEN 'Myocardial Infarction'
    WHEN REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") IN ('STTC', 'NST_', 'ISC_', 'ISCI', 'ISCAS', 'ISCLA') THEN 'ST/T Changes'
    WHEN REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") IN ('CLBBB', 'CRBBB', 'ILBBB', 'IRBBB', 'IVCD', 'LAFB') THEN 'Conduction Disturbance'
    WHEN REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") IN ('LVH', 'RVH', 'SEHYP') THEN 'Hypertrophy'
    ELSE 'Other/Rhythm'
  END AS superclass

FROM
  `ptb-xl-458415.ptbxl_data.ptbxl`,
  UNNEST(SPLIT(TRIM(scp_codes, '{}'), ',')) AS pair
where CAST(CAST(REGEXP_EXTRACT(pair, r":\s*([0-9.]+)") AS FLOAT64) AS INT64) >= 50
