1. Extended dataset by diagnoses and age categories
WITH DiagnosisAggregated AS (
  SELECT
    ecg_id,
    STRING_AGG(diagnose, ', ' ORDER BY diagnose ASC) AS diagnoses
  FROM (
    SELECT
      ecg_id,
      REGEXP_EXTRACT(pair, r"'?([^':\s{]+)'?\s*:") AS diagnose,
      CAST(CAST(REGEXP_EXTRACT(pair, r":\s*([0-9.]+)") AS FLOAT64) AS INT64) AS value
    FROM
      `ptb-xl-458415.ptbxl_data.ptbxl`,
      UNNEST(SPLIT(TRIM(scp_codes, '{}'), ',')) AS pair
  )
  WHERE value >= 50
  GROUP BY ecg_id
)

SELECT 
  t.*,
  CASE
    WHEN age = 0 OR age IS NULL THEN 'No data'
    WHEN age <= 18 THEN '0-18'
    WHEN age <= 39 THEN '19-39'
    WHEN age <= 59 THEN '40-59'
    WHEN age <= 69 THEN '60-69'
    WHEN age >= 70 THEN '70+'
  END AS age_category,
  d.diagnoses

FROM `ptb-xl-458415.ptbxl_data.ptbxl` AS t
LEFT JOIN DiagnosisAggregated AS d ON t.ecg_id = d.ecg_id
